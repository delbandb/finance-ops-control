# App name shown in docs and logs. Use something short.
APP_NAME=Finance Ops Control

# Use development locally. Valid values: development, test, production.
APP_ENV=development

# SQLite file location. This path also works with the Docker volume in this repo.
DATABASE_URL=sqlite:///./data/finance_ops_control.db

# Seeds the demo data on startup. Valid values: true, false.
SEED_ON_STARTUP=true

# Host for uvicorn. Keep 0.0.0.0 in Docker.
APP_HOST=0.0.0.0

# Port for the API server. Pick any free port if 8000 is busy.
APP_PORT=8000

# Logging level. Valid values: debug, info, warning, error.
LOG_LEVEL=info

# Placeholder secret key. Change this before any real deploy.
SECRET_KEY=change-me-before-real-deploy

# CORS origins. Use * for local testing, lock it down later.
ALLOWED_ORIGINS=*
